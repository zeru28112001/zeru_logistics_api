PORT=3000
JWT_SECRET=zeru-dev-secret-change-in-production

# ── Remote MongoDB server (replace YOUR_SERVER_HOST with IP or domain) ──
# Password special chars must be URL-encoded (@ → %40, # → %23, etc.)
DATABASE_URL="mongodb://admin:YOUR_PASSWORD@YOUR_SERVER_HOST:27017/zeru_logistics_api?authSource=admin"

# Example with encoded password (password is literally: myP@ss)
# DATABASE_URL="mongodb://admin:myP%40ss@192.168.1.100:27017/zeru_logistics_api?authSource=admin"

# ── MongoDB Atlas (cloud) ──
# DATABASE_URL="mongodb+srv://admin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/zeru_logistics_api?retryWrites=true&w=majority"

# ── Local dev (no auth) ──
# DATABASE_URL="mongodb://localhost:27017/zeru_logistics_api"
